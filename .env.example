# URL do projeto Supabase (REST API)
SUPABASE_URL=https://your-project.supabase.co

# service_role key do Supabase (Project Settings → API). NUNCA exponha no
# front-end — só é lida pela serverless function em api/lead.js, que insere
# direto na tabela public.webhook_leads_summary.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Senha compartilhada pra acessar o painel /roleta/admin de estoque durante o evento.
ADMIN_PASSPHRASE=troque-esta-senha
