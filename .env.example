# URL da Edge Function do Supabase que recebe os leads (webhook-lead)
SUPABASE_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/webhook-lead

# Token Bearer de autenticação do webhook. NUNCA exponha no front-end —
# só é lido pela serverless function em api/lead.js.
SUPABASE_WEBHOOK_TOKEN=your-secret-token
